# Server
PORT=8080
ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=orchestralog
DB_SSLMODE=disable

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_ACCESS_SECRET=change-this-access-secret-in-production
JWT_REFRESH_SECRET=change-this-refresh-secret-in-production
JWT_ACCESS_EXP_MINUTES=15
JWT_REFRESH_EXP_DAYS=7
